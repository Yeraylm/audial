# ============================================================
# Audial — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- Admin panel (panel oculto en /admin) ---
# Cambia esta clave antes de subir a producción
ADMIN_SECRET=audial-admin-2026

# --- LLM (elige uno) ---
# OPCIÓN A: Groq API (gratis, recomendado para cloud)
# Regístrate en https://console.groq.com y copia la API key
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile   # o mistral-saba-24b, gemma2-9b-it

# OPCIÓN B: Ollama local
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# --- Database ---
# SQLite (local, por defecto — no requiere nada)
# DATABASE_URL=sqlite:///./data/platform.db

# PostgreSQL — Supabase gratis: https://supabase.com
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# --- Whisper ---
WHISPER_MODEL=small          # tiny | base | small | medium  (tiny para cloud gratis)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=            # vacío = auto-detect

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_BACKEND=chroma         # chroma | faiss
